PORT=3001
NODE_ENV=development
PLATFORM_API_BASE=http://localhost:3000/v1/admin
PLATFORM_ADMIN_KEY=
DB_PATH=./data/erp.db
JWT_SECRET=please-change-me-in-production-this-is-a-dev-secret-32chars
JWT_EXPIRES_IN=7d
DEMO_SEED=true

# ===== P1-3 修复：CORS 白名单（逗号分隔）=====
# 本地默认允许这两个；生产部署时改成实际域名
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# ===== 修复结束 =====
