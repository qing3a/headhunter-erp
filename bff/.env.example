# ===== headhunter-api-hub 配置模板 =====
# 复制到 .env 并按需修改

# ===== 必改 =====
NODE_ENV=development                  # production / development / test
PORT=3001
JWT_SECRET=your-secret-here-change-me-to-32-plus-chars  # ⚠️ 必改 (≥32 字符)
DEMO_SEED=true                        # 生产设 false, 首次启动 seed 5 candidates + 5 jobs + 6 tasks + 3 interviews
CORS_ORIGINS=http://localhost:3001,http://localhost:8080  # 生产: 真实域名

# ===== 推荐改 =====
JWT_EXPIRES_IN=7d
DB_PATH=./data/erp.db                 # 生产: /var/lib/headhunter/erp.db

# ===== 可选 =====
REMINDER_SCAN=true                    # 启动时扫描 overdue 推荐, 自动转 pending_feedback
AUDIT_RETENTION=true                  # audit_log 自动清理
AUDIT_RETENTION_DAYS=90               # audit_log 保留天数

# ===== 平台 API（外部服务, 通常不需要）=====
PLATFORM_API_BASE=                    # 默认空 (platformApi.js 内部 fallback 到 http://localhost:3000/v1/admin)
PLATFORM_ADMIN_KEY=                   # 平台 admin key