{
  "name": "headhunter-api-hub",
  "version": "9.0.0-beta",
  "description": "Headhunter API Hub — pure API server (no frontend). Designed for collaboration with AI agents and sibling projects (e.g. ow-headhunter-erp).",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node src/db/init.js --seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "node ../tests/e2e-runner.js",
    "test:all": "npm test && npm run e2e",
    "openapi:generate": "node scripts/generate-openapi.js",
    "openapi:check": "node scripts/generate-openapi.js --check --strict"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
